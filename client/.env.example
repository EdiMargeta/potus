# ── Supabase (get from Project Settings → API) ─────────────────────────────
# Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# anon/public key — safe to expose in frontend
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# service_role key — only used inside the admin panel after password auth
# This bypasses RLS so admin can write to the database
VITE_SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── Admin ──────────────────────────────────────────────────────────────────
# Password shown at /admin — choose something strong
VITE_ADMIN_PASSWORD=change-me-to-something-strong
